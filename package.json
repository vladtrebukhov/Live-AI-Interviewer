{
  "name": "live-interviewer",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "corepack pnpm --dir packages/frontend exec eslint . --no-warn-ignored && corepack pnpm exec eslint --no-warn-ignored packages/backend/src packages/backend/prisma.config.ts packages/backend/prisma/seed.ts packages/shared/src eslint.config.js vitest.config.ts playwright.config.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "build": "corepack pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "db:migrate": "pnpm --filter @live-interviewer/backend exec prisma migrate dev",
    "db:seed": "pnpm --filter @live-interviewer/backend exec prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}