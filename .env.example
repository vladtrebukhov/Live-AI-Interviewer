# Copy this file to .env in the repository root.
# This single workspace env file is used by both the frontend and backend.

# Shared local app settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/live_interviewer
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_SPEECH_LOCALE=en-US

# Azure Speech (backend only)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus
# Optional: use a custom Speech endpoint only when required by your resource.
# For browser STT endpoint mode, provide an explicit speech path URL (contains /speech/).
# Do not set this to a regional Cognitive endpoint like https://<region>.api.cognitive.microsoft.com.
AZURE_SPEECH_ENDPOINT=https://<your-speech-resource>.cognitiveservices.azure.com

# Azure OpenAI (backend only)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper
AZURE_OPENAI_TTS_DEPLOYMENT=tts

# Optional: use a separate Azure OpenAI / Foundry resource for TTS.
# If omitted, TTS falls back to AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_API_KEY / AZURE_OPENAI_API_VERSION.
AZURE_OPENAI_TTS_ENDPOINT=https://<your-tts-resource-name>.openai.azure.com
AZURE_OPENAI_TTS_API_KEY=your-azure-tts-api-key
AZURE_OPENAI_TTS_API_VERSION=2025-04-01-preview
